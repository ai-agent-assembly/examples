# Agent Assembly gateway connection (required for production mode)
# Leave unset to run in offline / sdk-only demo mode
# AGENT_ASSEMBLY_GATEWAY_URL=http://localhost:8080
# AGENT_ASSEMBLY_API_KEY=your-api-key-here

