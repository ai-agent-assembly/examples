# Live-core enforcement — environment for the real SDK agent.
# Copy to .env (or export in your shell) when running the agent outside Docker.

# Agent identity. Determines the runtime socket name and the registered agent.
# MUST match the AA_AGENT_ID configured for the aa-runtime service.
AA_AGENT_ID=live-core-demo-agent

# Path to the runtime IPC socket the native SDK client connects to. Defaults to
# /tmp/aa-runtime-<AA_AGENT_ID>.sock when unset.
AA_RUNTIME_SOCKET=/tmp/aa-runtime-live-core-demo-agent.sock

# Gateway gRPC endpoint. Agent registration is a direct SDK -> gateway gRPC call
# (ADR 0004); the governed tool check then flows over the runtime UDS, which the
# runtime forwards to this same gateway. The bundled stack serves it on :50051.
#
# AA_GATEWAY_URL is the Python SDK's gateway handle. AA_GATEWAY_ENDPOINT is the
# knob the *native* SDK client reads for the direct registration gRPC call (it
# defaults to 127.0.0.1:50051). Set both to the gateway's gRPC address.
AA_GATEWAY_URL=http://localhost:50051
AA_GATEWAY_ENDPOINT=http://localhost:50051
